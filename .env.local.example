# Pinterest OAuth — create an app at https://developers.pinterest.com/apps/
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/auth/callback

# iron-session cookie encryption key (32+ chars)
SESSION_SECRET=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Turso (libSQL) — leave unset for local dev (falls back to file:./data/designr.db)
# Get these from https://app.turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
